# Python
__pycache__/
*.pyc
*.egg-info/

# Data cache (large, regenerable)
data/librispeech/
data/common_voice/

# torch.compile Inductor cache — run-local
.inductor_cache/
**/.inductor_cache/

# Final-stage policy: COMMIT model weights for thesis reproducibility.
# Counter to formal_v1/.gitignore (which excludes *.pt). The single
# best_model.pt per run is committed under outputs/<exp_name>_seed42/.
# Per-epoch diagnostic snapshots (ep1/ep5/ep15/ep30/best/final) keep
# their JSON committed; the .pt they reference via model_state_path
# stays local under outputs/<exp_name>_seed42/checkpoints/ and is NOT
# committed (those are kept for in-flight diagnostics, not archived).

outputs/*/checkpoints/
outputs/*/checkpoints/**

# Codebase saves per-epoch diagnostic snapshots at run-dir top level
# (not in a checkpoints/ subdir as the §13 spec text suggests). They
# are kept local for in-flight diagnostics and NOT committed —
# only best_model.pt is. last_model.pt is the resume target and also
# kept local (regenerable from best_model.pt + history).
outputs/*/checkpoint_ep*.pt
outputs/*/last_model.pt

# Launch-script logs (master + per-run) duplicate train.log content
# and grow without bound — keep local.
outputs/_50ep_singles_launch_logs/
outputs/_50ep_lion_vanilla_launch_logs/
outputs/_50ep_lion_multidil_v2_launch_logs/

# Pre-fix runs of buggy implementations — kept locally for diagnosis
# (e.g. magnitude-of-bug evidence) but not committed as canonical results.
# The canonical run-dir name (without the _PRE_*_FIX suffix) holds the
# fixed result.
outputs/*_PRE_*_FIX_*/
